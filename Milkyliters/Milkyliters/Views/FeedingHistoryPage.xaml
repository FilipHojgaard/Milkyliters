<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milkyliters.Views.FeedingHistoryPage"
             Title="Mad Historik">

    <CollectionView ItemsSource="{Binding FeedingGroups}" IsGrouped="True">
    
        <CollectionView.GroupHeaderTemplate>
            <DataTemplate>
                <Border Stroke="#CCCCCC" StrokeThickness="3" Margin="16, 32, 16, 0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*, Auto" Padding="16,8">
                        <Label Grid.Column="0" Text="{Binding LocalDay}" FontSize="16" FontFamily="NunitoBold" />
                        <Label Grid.Column="1" Text="{Binding TotalMl, StringFormat='{0} ml'}" FontSize="16" FontFamily="NunitoBold"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Stroke="#CCCCCC" StrokeThickness="1" Margin="32, 0, 16, 0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,8">
                        <Label Grid.Column="0" Text="{Binding LocalTime}" FontSize="16" FontFamily="NunitoRegular" />
                        <Label Grid.Column="1" Text="{Binding Ml, StringFormat='{0} ml'}" FontSize="16" FontFamily="NunitoRegular" HorizontalOptions="Center"/>
                        <Label Grid.Column="2" Text="{Binding Milktype}" FontSize="16" FontFamily="NunitoRegular" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>