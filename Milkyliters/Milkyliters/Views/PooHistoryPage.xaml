<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milkyliters.Views.PooHistoryPage"
             Title="Poo">


    <CollectionView ItemsSource="{Binding PooGroups}" IsGrouped="True">

        <CollectionView.GroupHeaderTemplate>
            <DataTemplate>
                <Border Stroke="#CCCCCC" StrokeThickness="3" Margin="16, 32, 16, 0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*, Auto" Padding="16,8">
                        <Label Grid.Column="0" Text="{Binding LocalDate}" FontSize="16" FontFamily="NunitoBold" />
                        <Label Grid.Column="1" Text="{Binding TotalPoo, StringFormat='Total: {0}'}" FontSize="16" FontFamily="NunitoBold"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <SwipeView>
                    <SwipeView.RightItems>
                        <SwipeItems>
                            <SwipeItem Text="Slet"
                                       BackgroundColor="Red"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DeletePooCommand}"
                                       CommandParameter="{Binding .}" />
                        </SwipeItems>
                    </SwipeView.RightItems>

                    <Border Stroke="#CCCCCC" StrokeThickness="1" Margin="32, 0, 16, 0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,8">
                            <Label Grid.Column="0" Text="{Binding LocalTime}" FontSize="16" FontFamily="NunitoRegular" />
                        </Grid>
                    </Border>
                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>


</ContentPage>