<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Milkyliters.Views.MainPage">

    <Grid RowDefinitions="*, Auto">
        <VerticalStackLayout
            Grid.Row="0"
            Padding="20,0"
            Margin="0, 64, 0, 0"
            Spacing="64">
            <HorizontalStackLayout
                Spacing="64"
                HorizontalOptions="Center">
                <VerticalStackLayout
                    Spacing="2">
                    <Label
                            Text="{Binding MlToday}"
                            FontSize="32"
                            FontAttributes="Bold"
                            HorizontalOptions="Center" />

                    <Label
                            Text="Ml today"
                            FontSize="16"
                            FontAttributes="None"
                            HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Spacing="2">
                    <Label
                        Text="{Binding MlLast24Hours}"
                        FontSize="32"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />
                    <Label
                        Text="Ml last 24 hours"
                        FontSize="16"
                        FontAttributes="None"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <VerticalStackLayout
                Spacing="2">
                <Label
                    Text="{Binding DaysSinceLastPoo, TargetNullValue='-'}"
                    FontSize="32"
                    FontAttributes="Bold"
                    HorizontalOptions="Center" />
                <Label
                    Text="Days since last poo"
                    FontSize="16"
                    FontAttributes="None"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1">
            <HorizontalStackLayout
                Spacing="16"
                HorizontalOptions="Center">
                <Entry
                    Keyboard="Numeric"
                    Text="{Binding AddMl, Mode=TwoWay}" />

                <Button
                    Text="Submit"
                    Command="{Binding AddFeedingCommand}"
                    HorizontalOptions="Fill" />

            </HorizontalStackLayout>

            <Button
                Text="Add Poo"
                Margin="0, 16, 0, 0"
                Command="{Binding AddPooCommand}"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </Grid>

    



</ContentPage>
