<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Milkyliters.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Milkyliters"
    xmlns:Views="clr-namespace:Milkyliters.Views"
    Title="Milkyliters">

    <TabBar>
        <Tab Title="Hjem">
            <ShellContent ContentTemplate="{DataTemplate Views:MainPage}" />
        </Tab>
        <Tab Title="Mad">
            <ShellContent ContentTemplate="{DataTemplate Views:FeedingHistoryPage}" />
        </Tab>
        <Tab Title="Poo">
            <ShellContent ContentTemplate="{DataTemplate Views:PooHistoryPage}" />
        </Tab>
    </TabBar>

</Shell>
